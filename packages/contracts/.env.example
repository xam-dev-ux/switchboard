# ── packages/contracts/.env ──────────────────────────────────
# Deploy-time only. NEVER commit this file. NEVER share these values.
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Tu wallet personal (deployer / owner) ────────────────────
# Genera con: cast wallet new
# Esta wallet es OWNER del contrato y puede llamar withdraw()
DEPLOY_PRIVATE_KEY=0x...
OWNER_WALLET_ADDRESS=0x...

# ── Wallet del agente (el que va a Render) ───────────────────
# Genera con: cast wallet new  →  pon aquí la ADDRESS, NO la clave privada
AGENT_WALLET_ADDRESS=0x...

# ── Builder code ─────────────────────────────────────────────
# Regístralo en api.base.dev con tu wallet personal
BUILDER_CODE=bc_...

# ── Basescan (opcional, para verificar el contrato) ──────────
# Obtén tu key en: https://basescan.org/myapikey
BASESCAN_API_KEY=

# ── ERC-8004 Registry addresses (no cambies salvo hard fork) ─
ERC8004_IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
ERC8004_REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
