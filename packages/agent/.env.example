# ── packages/agent/.env ──────────────────────────────────────
# Runtime secrets for Render. NEVER commit this file.
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  OWNER_WALLET_ADDRESS and DEPLOY_PRIVATE_KEY go in packages/contracts/.env
#     NOT here — they are deploy-time only and must never reach Render.

# Agent wallet private key — stays in Render, never share
AGENT_PRIVATE_KEY=

# Public address derived from AGENT_PRIVATE_KEY
AGENT_WALLET_ADDRESS=

# SwitchboardVault address — output of the deploy script (deployments/base.json)
VAULT_ADDRESS=0x...

# Builder code registered at api.base.dev with your personal wallet
BUILDER_CODE=bc_...

# Base RPC (public endpoint is fine for MVP)
BASE_RPC_URL=https://mainnet.base.org

# User fee in USDC 6-decimals ($0.05)
USER_FEE=50000

# Minimum margin per job in USDC 6-decimals ($0.01)
MIN_MARGIN=10000

# HTTP port (Render sets this automatically)
PORT=3000

# Public URL of this service — set AFTER first Render deploy
BOT_URL=https://switchboard.onrender.com
